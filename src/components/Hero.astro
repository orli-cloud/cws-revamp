<section class="hero" data-trail-zone>
	<div class="hero-inner">
		<h1 class="display hero-headline">
			<span class="line line-1">You didn't know making a</span>
			<span class="line line-2">website could be <span class="hl">this easy.</span></span>
		</h1>

		<p class="hero-punch">
			With CWS, <em>it is.</em>
		</p>

		<p class="hero-sub">
			CWS builds your web presence just the way you want it, with clear
			communication, a smooth process, and results you'll be thrilled with.
		</p>

		<div class="hero-cta">
			<a href="#testimonials" class="btn btn-ghost">
				<span>See what clients say</span>
				<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
					<path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</a>
			<a href="#work" class="btn btn-primary">
				<span>See work</span>
				<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
					<path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>

		<p class="hero-pssst">
			<svg class="pssst-arrow" viewBox="0 0 60 36" aria-hidden="true">
				<path
					d="M5 30 C 18 28, 28 18, 38 8"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
				/>
				<path
					d="M38 8 L 32 10 M38 8 L 36 14"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
			<span>
				<em>Pssst!</em> We have a 68% return rate and 97% of our new clients are referrals. Coincidence? You can be the judge.
			</span>
		</p>
	</div>

	<!-- Trail layer with real CWS portfolio images -->
	<div class="trail" data-trail aria-hidden="true">
		{
			mockups.map((src, i) => (
				<template data-variant={i}>
					<div class="mock-card">
						<img src={src} alt="" loading="lazy" />
					</div>
				</template>
			))
		}
	</div>
</section>

<div class="cursor-dot" data-cursor aria-hidden="true"></div>

<style>
	.hero {
		position: relative;
		height: calc(100svh - 100px);
		min-height: 560px;
		max-height: 840px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		isolation: isolate;
		cursor: none;
	}

	.hero::before,
	.hero::after {
		content: "";
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		z-index: -1;
		pointer-events: none;
	}
	.hero::before {
		width: 540px;
		height: 540px;
		background: radial-gradient(closest-side, var(--teal-soft), transparent 70%);
		top: -160px;
		left: -180px;
	}
	.hero::after {
		width: 460px;
		height: 460px;
		background: radial-gradient(closest-side, var(--gold-soft), transparent 70%);
		top: 120px;
		right: -120px;
		opacity: 0.55;
	}

	.hero-inner {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 22px;
		max-width: 1100px;
		padding: 0 var(--gutter);
		pointer-events: none;
	}
	.hero-inner > * { pointer-events: auto; }

	.hero-headline {
		font-size: clamp(40px, 5.6vw, 92px);
		margin: 0;
		font-weight: 700;
		letter-spacing: -0.028em;
		line-height: 1.02;
	}
	.hero-headline .line {
		display: block;
		white-space: nowrap;
	}
	.hero-headline .line-1 { animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both; animation-delay: 0.1s; }
	.hero-headline .line-2 { animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both; animation-delay: 0.22s; }
	.hero-headline .line-3 { animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both; animation-delay: 0.34s; }
	.hero-headline em {
		font-style: normal;
		color: var(--orange);
		font-weight: 700;
	}

	.hero-headline .hl {
		display: inline-block;
		color: var(--orange);
		position: relative;
		padding: 0 0.04em;
	}
	.hero-headline .hl::after {
		content: "";
		position: absolute;
		left: 4%;
		right: 4%;
		bottom: -0.06em;
		height: 0.16em;
		background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 18' preserveAspectRatio='none'><path d='M2 12 C 40 2, 80 18, 120 8 S 198 14, 198 4' fill='none' stroke='%23147c91' stroke-width='2.4' stroke-linecap='round'/></svg>") no-repeat center / 100% 100%;
		transform-origin: left;
		animation: drawWave 1.2s cubic-bezier(0.65, 0, 0.35, 1) 0.9s both;
	}
	@keyframes drawWave { from { transform: scaleX(0); } to { transform: scaleX(1); } }
	@keyframes rise {
		from { opacity: 0; transform: translateY(28px); }
		to { opacity: 1; transform: none; }
	}

	@media (max-width: 720px) {
		.hero-headline .line { white-space: normal; }
	}

	.hero-punch {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: clamp(20px, 2vw, 30px);
		color: var(--teal-deep);
		letter-spacing: -0.012em;
		margin: 0;
		animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both;
		animation-delay: 0.4s;
	}
	.hero-punch em {
		font-style: normal;
		color: var(--orange);
		font-weight: 700;
	}

	.hero-sub {
		font-size: clamp(15px, 1.2vw, 18px);
		line-height: 1.55;
		color: var(--ink-mute);
		max-width: 580px;
		margin: 0;
		font-weight: 400;
		animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both;
		animation-delay: 0.55s;
	}

	.hero-cta {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 4px;
		animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both;
		animation-delay: 0.7s;
	}

	.hero-pssst {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin: 18px auto 0;
		font-size: 0.78rem;
		line-height: 1.3;
		color: var(--ink-mute);
		text-align: left;
		white-space: nowrap;
		animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.1, 1) both;
		animation-delay: 0.85s;
	}
	@media (max-width: 880px) {
		.hero-pssst { white-space: normal; max-width: 480px; }
	}
	.hero-pssst em {
		font-style: normal;
		font-weight: 700;
		color: var(--orange);
	}
	.pssst-arrow {
		flex-shrink: 0;
		width: 42px;
		height: 26px;
		color: var(--orange);
		transform: translateY(-2px);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 16px 26px;
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.96rem;
		transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease, gap 0.25s ease;
		cursor: none;
		border: 1.5px solid transparent;
	}
	.btn-primary {
		background: var(--teal-ink);
		color: var(--paper);
		box-shadow: 0 12px 30px -14px rgba(8, 43, 54, 0.6);
	}
	.btn-primary:hover { background: var(--orange); gap: 16px; }
	.btn-ghost {
		background: transparent;
		color: var(--teal-deep);
		border-color: var(--hairline-strong);
	}
	.btn-ghost:hover { background: #fff; border-color: var(--teal); gap: 16px; }

	/* Trail layer — sits ABOVE the hero content */
	.trail {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 5;
	}
	.trail template { display: none; }

	.mock-card {
		position: absolute;
		width: 280px;
		max-width: 30vw;
		aspect-ratio: 4 / 3;
		border-radius: 14px;
		overflow: hidden;
		background: #fff;
		box-shadow:
			0 24px 50px -24px rgba(8, 43, 54, 0.45),
			0 0 0 1px rgba(0, 0, 0, 0.06);
		opacity: 0;
		transform: translate(-50%, calc(-50% + 8px)) rotate(var(--r, 0deg)) scale(0.92);
		transition:
			opacity 0.5s cubic-bezier(0.22, 0.61, 0.36, 1),
			transform 0.65s cubic-bezier(0.22, 0.61, 0.36, 1);
		will-change: transform, opacity;
	}
	.mock-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.mock-card.in {
		opacity: 1;
		transform: translate(-50%, -50%) rotate(var(--r, 0deg)) scale(1);
	}
	.mock-card.out {
		opacity: 0;
		transform: translate(-50%, calc(-50% - 14px)) rotate(var(--r, 0deg)) scale(0.97);
	}

	/* Custom dot cursor */
	.cursor-dot {
		position: fixed;
		top: 0;
		left: 0;
		width: 14px;
		height: 14px;
		margin: -7px 0 0 -7px;
		border-radius: 50%;
		background: var(--orange);
		pointer-events: none;
		opacity: 0;
		z-index: 60;
		transition: opacity 0.25s ease, width 0.3s ease, height 0.3s ease, margin 0.3s ease, background 0.3s ease;
		box-shadow: 0 0 0 4px rgba(247, 128, 64, 0.18);
	}
	.cursor-dot.is-on { opacity: 1; }
	.cursor-dot.over-btn {
		width: 56px;
		height: 56px;
		margin: -28px 0 0 -28px;
		background: var(--teal-ink);
	}

	@media (max-width: 760px) {
		.hero { height: auto; min-height: 0; padding: 60px 0 80px; cursor: auto; }
		.hero-inner { gap: 18px; }
		.btn { cursor: pointer; }
	}

	@media (hover: none) {
		.hero { cursor: auto; }
		.btn { cursor: pointer; }
		.trail, .cursor-dot { display: none; }
	}
</style>

<script>
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const isTouch = window.matchMedia("(hover: none)").matches;

	const zone = document.querySelector<HTMLElement>("[data-trail-zone]");
	const trail = document.querySelector<HTMLElement>("[data-trail]");
	const cursorDot = document.querySelector<HTMLElement>("[data-cursor]");

	if (zone && trail && cursorDot && !isTouch) {
		const templates = Array.from(trail.querySelectorAll<HTMLTemplateElement>("template"));
		const variants = templates.map((t) => t.innerHTML.trim());

		let lastX = 0;
		let lastY = 0;
		let i = 0;
		const minDist = 80;

		const cursorMove = (e: MouseEvent) => {
			cursorDot.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
		};

		zone.addEventListener("mouseenter", (e) => {
			cursorDot.classList.add("is-on");
			lastX = (e as MouseEvent).clientX;
			lastY = (e as MouseEvent).clientY;
			cursorMove(e as MouseEvent);
		});
		zone.addEventListener("mouseleave", () => {
			cursorDot.classList.remove("is-on");
		});

		zone.addEventListener("mousemove", (e) => {
			cursorMove(e);
			if (reduce) return;

			const dx = e.clientX - lastX;
			const dy = e.clientY - lastY;
			if (Math.hypot(dx, dy) < minDist) return;
			lastX = e.clientX;
			lastY = e.clientY;

			const html = variants[i % variants.length];
			i++;
			const wrapper = document.createElement("div");
			wrapper.innerHTML = html;
			const card = wrapper.firstElementChild as HTMLElement;
			if (!card) return;

			const zoneRect = zone.getBoundingClientRect();
			const localX = e.clientX - zoneRect.left;
			const localY = e.clientY - zoneRect.top;
			const r = (Math.random() - 0.5) * 16;

			card.style.left = `${localX}px`;
			card.style.top = `${localY}px`;
			card.style.setProperty("--r", `${r}deg`);

			const cardImg = card.querySelector<HTMLImageElement>("img");
			if (cardImg) {
				cardImg.addEventListener("error", () => {
					card.remove();
					const idx = variants.indexOf(html);
					if (idx !== -1) variants.splice(idx, 1);
				}, { once: true });
			}

			trail.appendChild(card);
			// Two RAFs to ensure initial styles paint before transition
			requestAnimationFrame(() =>
				requestAnimationFrame(() => card.classList.add("in"))
			);
			setTimeout(() => card.classList.add("out"), 1100);
			setTimeout(() => card.remove(), 1800);

			const cards = trail.querySelectorAll(".mock-card");
			if (cards.length > 14) cards[0].remove();
		});

		zone.querySelectorAll<HTMLElement>(".btn").forEach((b) => {
			b.addEventListener("mouseenter", () => cursorDot.classList.add("over-btn"));
			b.addEventListener("mouseleave", () => cursorDot.classList.remove("over-btn"));
		});
	}
</script>

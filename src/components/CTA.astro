---
---

<section id="contact" class="cta" data-spotlight>
	<!-- Cursor-tracking spotlight -->
	<div class="spot" data-spot></div>

	<!-- Decorative dots -->
	<span class="deco-dot dot-1" aria-hidden="true"></span>
	<span class="deco-dot dot-2" aria-hidden="true"></span>
	<span class="deco-dot dot-3" aria-hidden="true"></span>

	<!-- Floating rotating badge -->
	<div class="orbit" aria-hidden="true">
		<svg viewBox="0 0 200 200" width="160" height="160">
			<defs>
				<path id="orbit-path" d="M100,100 m-72,0 a72,72 0 1,1 144,0 a72,72 0 1,1 -144,0" />
			</defs>
			<text class="orbit-text" font-family="Gilroy, sans-serif" font-weight="900" font-size="14" letter-spacing="6" fill="var(--gold)">
				<textPath href="#orbit-path" startOffset="0">
					AVAILABLE NOW · TALK TO MARTIN ·
				</textPath>
			</text>
			<g transform="translate(100 100)">
				<circle r="30" fill="var(--orange)" />
				<path d="M-8 0 L 8 0 M 2 -6 L 8 0 L 2 6"
					stroke="#fff" stroke-width="2.4" fill="none"
					stroke-linecap="round" stroke-linejoin="round" />
			</g>
		</svg>
	</div>

	<div class="wrap cta-inner reveal">
		<h2 class="display cta-title">
			<span class="line">Let's get</span>
			<span class="line">it <em>done.</em></span>
		</h2>

		<p class="cta-sub">
			We make it easy.
		</p>

		<div class="cta-actions">
			<a href="mailto:hello@cwsio.com" class="btn-cta primary" data-mag>
				<span class="btn-text">
					<span class="btn-line">Get in touch</span>
					<span class="btn-line">Let's go</span>
				</span>
				<span class="btn-arrow" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="14" height="14">
						<path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</span>
			</a>

			<a href="https://wa.me/" target="_blank" rel="noopener" class="btn-cta ghost">
				<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
					<path d="M20.52 3.48A11.93 11.93 0 0 0 12.05 0C5.42 0 .03 5.39.03 12c0 2.12.55 4.18 1.6 6L0 24l6.18-1.62a12 12 0 0 0 5.87 1.5h.01c6.62 0 12.01-5.39 12.01-12 0-3.21-1.25-6.22-3.55-8.4Z" fill="currentColor"></path>
				</svg>
				<span>Whatsapp Martin</span>
			</a>
		</div>

		<p class="cta-pssst">
			<svg class="pssst-arrow" viewBox="0 0 60 36" aria-hidden="true">
				<path
					d="M5 30 C 18 28, 28 18, 38 8"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
				/>
				<path
					d="M38 8 L 32 10 M38 8 L 36 14"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
			<span>
				<em>Pssst!</em> We have a 68% return rate and 97% of our new clients are referrals. Coincidence? You can be the judge.
			</span>
		</p>
	</div>
</section>

<style>
	.cta {
		position: relative;
		padding: clamp(80px, 12vw, 180px) 0;
		background: var(--teal-ink);
		color: var(--paper);
		text-align: center;
		overflow: hidden;
		isolation: isolate;
	}

	/* Subtle ambient glow always present */
	.cta::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 80% 20%, rgba(252, 182, 38, 0.18) 0%, transparent 55%),
			radial-gradient(ellipse at 15% 85%, rgba(247, 128, 64, 0.14) 0%, transparent 55%);
		pointer-events: none;
		z-index: -1;
	}

	/* Animated dotted grid */
	.cta::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image: radial-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 0);
		background-size: 28px 28px;
		mask-image: linear-gradient(180deg, transparent 0%, #000 25%, #000 75%, transparent 100%);
		-webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 25%, #000 75%, transparent 100%);
		pointer-events: none;
		z-index: -1;
	}

	/* Cursor spotlight */
	.spot {
		position: absolute;
		width: 540px;
		height: 540px;
		border-radius: 50%;
		background: radial-gradient(closest-side, rgba(252, 182, 38, 0.28) 0%, rgba(247, 128, 64, 0.12) 35%, transparent 70%);
		filter: blur(50px);
		pointer-events: none;
		opacity: 0;
		transform: translate3d(-100vw, -100vw, 0) translate(-50%, -50%);
		transition: opacity 0.5s ease;
		z-index: 0;
		mix-blend-mode: screen;
	}
	.cta.is-hover .spot { opacity: 1; }

	/* Decorative dots */
	.deco-dot {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}
	.dot-1 {
		width: 14px;
		height: 14px;
		background: var(--orange);
		top: 18%;
		left: 8%;
		box-shadow: 0 0 0 8px rgba(247, 128, 64, 0.18);
		animation: float-dot 4s ease-in-out infinite;
	}
	.dot-2 {
		width: 8px;
		height: 8px;
		background: var(--gold);
		bottom: 22%;
		left: 14%;
		box-shadow: 0 0 0 6px rgba(252, 182, 38, 0.18);
		animation: float-dot 5.5s ease-in-out infinite -1.5s;
	}
	.dot-3 {
		width: 10px;
		height: 10px;
		background: var(--teal);
		top: 30%;
		right: 12%;
		box-shadow: 0 0 0 7px rgba(20, 124, 145, 0.22);
		animation: float-dot 4.8s ease-in-out infinite -2.2s;
	}
	@keyframes float-dot {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(0, -16px); }
	}

	/* Rotating orbital badge */
	.orbit {
		position: absolute;
		bottom: 8%;
		right: 6%;
		z-index: 2;
		pointer-events: none;
		filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.35));
	}
	.orbit svg {
		display: block;
		animation: orbit-spin 14s linear infinite;
	}
	@keyframes orbit-spin {
		to { transform: rotate(360deg); }
	}

	@media (max-width: 760px) {
		.orbit {
			bottom: auto;
			top: 24px;
			right: 24px;
		}
		.orbit svg { width: 110px; height: 110px; }
	}

	/* Inner content */
	.cta-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 22px;
	}

	.cta-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 9px 18px 9px 14px;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(6px);
	}
	.ping {
		position: relative;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--gold);
	}
	.ping::after {
		content: "";
		position: absolute;
		inset: -4px;
		border-radius: 50%;
		background: var(--gold);
		opacity: 0.4;
		animation: ping 1.6s cubic-bezier(0, 0, 0.2, 1) infinite;
	}
	@keyframes ping {
		0% { transform: scale(0.6); opacity: 0.5; }
		70% { transform: scale(1.8); opacity: 0; }
		100% { transform: scale(1.8); opacity: 0; }
	}

	.cta-title {
		font-size: clamp(64px, 11vw, 188px);
		margin: 0;
		font-weight: 700;
		line-height: 0.92;
		letter-spacing: -0.04em;
		color: var(--paper);
	}
	.cta-title .line { display: block; }
	.cta-title em {
		font-style: normal;
		color: var(--orange);
		display: inline-block;
		position: relative;
	}
	.cta-title em::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0.04em;
		height: 0.16em;
		background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 18' preserveAspectRatio='none'><path d='M2 12 C 40 2, 80 18, 120 8 S 198 14, 198 4' fill='none' stroke='%23fcb626' stroke-width='2.6' stroke-linecap='round'/></svg>") no-repeat center / 100% 100%;
		transform-origin: left;
		animation: draw 1.2s cubic-bezier(0.65, 0, 0.35, 1) 0.5s both;
	}
	@keyframes draw {
		from { transform: scaleX(0); }
		to { transform: scaleX(1); }
	}

	.cta-sub {
		font-family: var(--font-sans);
		font-weight: 700;
		color: var(--gold);
		font-size: clamp(20px, 1.8vw, 28px);
		letter-spacing: -0.012em;
		margin: 0;
	}

	.cta-actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 14px;
	}

	.btn-cta {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 18px 24px 18px 30px;
		border-radius: 999px;
		font-weight: 700;
		font-size: 1rem;
		transition: transform 0.25s ease, background 0.3s ease, gap 0.25s ease;
		border: 1.5px solid transparent;
		overflow: hidden;
		will-change: transform;
	}
	.btn-cta.primary {
		background: var(--orange);
		color: #fff;
		box-shadow:
			0 18px 40px -16px rgba(247, 128, 64, 0.7),
			0 0 0 1px rgba(255, 255, 255, 0.06) inset;
	}
	.btn-cta.primary:hover { background: var(--gold); color: var(--teal-ink); }
	.btn-cta.primary:hover .btn-arrow { background: var(--teal-ink); color: var(--gold); transform: rotate(-45deg); }

	.btn-text {
		position: relative;
		display: inline-block;
		height: 1.1em;
		overflow: hidden;
	}
	.btn-line {
		display: block;
		transition: transform 0.45s cubic-bezier(0.7, 0, 0.2, 1);
	}
	.btn-cta.primary:hover .btn-line { transform: translateY(-100%); }

	.btn-arrow {
		display: inline-flex;
		width: 32px;
		height: 32px;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.22);
		color: #fff;
		transition: background 0.3s ease, transform 0.3s ease, color 0.3s ease;
	}

	.btn-cta.ghost {
		background: rgba(255, 255, 255, 0.06);
		color: #fff;
		border-color: rgba(255, 255, 255, 0.18);
		backdrop-filter: blur(4px);
	}
	.btn-cta.ghost:hover {
		background: rgba(255, 255, 255, 0.14);
		border-color: rgba(255, 255, 255, 0.3);
		gap: 14px;
	}

	.cta-pssst {
		display: flex;
		align-items: center;
		gap: 8px;
		width: fit-content;
		max-width: 540px;
		margin: 26px auto 0;
		font-size: 0.84rem;
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.7);
		text-align: left;
	}
	.cta-pssst em {
		font-style: normal;
		font-weight: 700;
		color: var(--orange);
	}
	.cta-pssst .pssst-arrow {
		flex-shrink: 0;
		width: 42px;
		height: 26px;
		color: var(--orange);
		transform: translateY(-2px);
	}
</style>

<script>
	const cta = document.querySelector<HTMLElement>("[data-spotlight]");
	const spot = document.querySelector<HTMLElement>("[data-spot]");
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (cta && spot && !reduce) {
		let raf = 0, sx = 0, sy = 0, mx = 0, my = 0;
		const tick = () => {
			sx += (mx - sx) * 0.18;
			sy += (my - sy) * 0.18;
			spot.style.transform = `translate3d(${sx}px, ${sy}px, 0) translate(-50%, -50%)`;
			if (Math.abs(mx - sx) > 0.5 || Math.abs(my - sy) > 0.5) {
				raf = requestAnimationFrame(tick);
			} else {
				raf = 0;
			}
		};
		cta.addEventListener("mouseenter", (e) => {
			cta.classList.add("is-hover");
			const r = cta.getBoundingClientRect();
			mx = (e as MouseEvent).clientX - r.left;
			my = (e as MouseEvent).clientY - r.top;
			sx = mx;
			sy = my;
			spot.style.transform = `translate3d(${sx}px, ${sy}px, 0) translate(-50%, -50%)`;
		});
		cta.addEventListener("mouseleave", () => {
			cta.classList.remove("is-hover");
		});
		cta.addEventListener("mousemove", (e) => {
			const r = cta.getBoundingClientRect();
			mx = (e as MouseEvent).clientX - r.left;
			my = (e as MouseEvent).clientY - r.top;
			if (!raf) raf = requestAnimationFrame(tick);
		});
	}
</script>

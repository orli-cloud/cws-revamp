---
const items = [
	{ name: "Sunray ABA", industry: "Healthcare" },
	{ name: "Bright Peak", industry: "ABA" },
	{ name: "Kennedy ABA", industry: "Therapy" },
	{ name: "Ablestars", industry: "ABA" },
	{ name: "Move Up ABA", industry: "Therapy" },
	{ name: "Little Acorn", industry: "Pediatric" },
	{ name: "Aber Weiss", industry: "Wellness" },
	{ name: "Sheindel & Co", industry: "Custom dev" },
	{ name: "Cignature", industry: "Financial" },
	{ name: "Madreigos", industry: "Education" },
	{ name: "Ascend", industry: "Coaching" },
	{ name: "Future Mark", industry: "Wellness" },
];
const dup = [...items, ...items];
---

<section class="marquee" aria-label="Selected clients">

	<div class="ticker">
		<div class="track">
			{
				dup.map((it, i) => (
					<div class="chip" data-idx={i}>
						<span class="chip-name">{it.name}</span>
						<span class="chip-dot" aria-hidden="true">●</span>
						<span class="chip-ind">{it.industry}</span>
					</div>
				))
			}
		</div>
	</div>

	<div class="ticker reverse">
		<div class="track">
			{
				dup.map((it, i) => (
					<div class="chip alt" data-idx={i}>
						<span class="chip-name">{it.name}</span>
						<span class="chip-dot" aria-hidden="true">●</span>
						<span class="chip-ind">{it.industry}</span>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.marquee {
		padding: clamp(48px, 7vw, 96px) 0;
		background: var(--paper);
		overflow: hidden;
		position: relative;
	}

	.marquee-head {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin-bottom: 32px;
	}

	.marquee-tag {
		font-size: clamp(15px, 1.1vw, 17px);
		color: var(--ink-mute);
		margin: 0;
		max-width: 540px;
	}

	.ticker {
		display: flex;
		overflow: hidden;
		mask-image: linear-gradient(
			to right,
			transparent 0%,
			#000 12%,
			#000 88%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent 0%,
			#000 12%,
			#000 88%,
			transparent 100%
		);
	}

	.ticker + .ticker {
		margin-top: 14px;
	}

	.track {
		display: flex;
		gap: 18px;
		flex-shrink: 0;
		animation: scroll 38s linear infinite;
		padding-right: 18px;
	}
	.ticker.reverse .track {
		animation-direction: reverse;
		animation-duration: 46s;
	}

	@keyframes scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	.ticker:hover .track {
		animation-play-state: paused;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 18px;
		flex-shrink: 0;
		padding: 22px 34px;
		border: 1px solid var(--hairline);
		border-radius: 999px;
		background: var(--paper);
		font-size: 1.18rem;
		font-weight: 500;
		color: var(--teal-ink);
		transition: all 0.25s ease;
	}
	.chip.alt {
		background: transparent;
		border-color: var(--hairline-strong);
	}
	.chip:hover {
		background: var(--teal-ink);
		color: var(--paper);
		border-color: var(--teal-ink);
	}
	.chip:hover .chip-dot {
		color: var(--orange);
	}
	.chip:hover .chip-ind {
		color: rgba(255, 255, 255, 0.7);
	}

	.chip-name {
		font-weight: 700;
		letter-spacing: -0.014em;
		font-size: 1.18rem;
	}

	.chip-dot {
		color: var(--gold);
		font-size: 0.7rem;
	}

	.chip-ind {
		color: var(--ink-mute);
		font-weight: 500;
		font-size: 1.02rem;
	}
</style>

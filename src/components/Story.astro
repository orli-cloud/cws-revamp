---
// Scrollytelling manifesto: pinned section with 2 scenes that fade in/out
// as the user scrolls. Mobile gracefully degrades to a vertical reveal flow.

// Scene 1 — "Meet CWS" with three things we care about, staggered in on scroll.
// Headline is split into two explicit lines and each char reveals on scroll.
const meetHeadlineLines = [
	["We", "care", "about"],
	["getting", "it", "right."],
];
const cares = [
	"for your goals",
	"for what your business actually needs",
	"and every detail that goes into building your online presence.",
];

// Scene 2 — closer headline split into two explicit lines.
// Line 1 (white) is the statement; Line 2 (orange `emph`) is the call.
// Each word's letters reveal one-at-a-time on scroll.
const closerLines = [
	[
		{ text: "We'll", emph: false },
		{ text: "take", emph: false },
		{ text: "it", emph: false },
		{ text: "from", emph: false },
		{ text: "here.", emph: false },
	],
	[
		{ text: "Let's", emph: true },
		{ text: "do", emph: true },
		{ text: "this.", emph: true },
	],
];
---

<!-- Top spacer so the Services → Story transition has breathing room. -->
<div class="story-head" aria-hidden="true"></div>

<section class="story" data-story aria-label="Meet CWS">
	<div class="story-pin">
		<div class="story-inner">
			<!-- Scene 1 — Meet CWS. Headline split into two explicit lines
			     and each char reveals letter-by-letter via JS. -->
			<div class="scene meet" data-scene="0">
				<p class="kicker">Meet CWS</p>
				<h2 class="scene-h letters" data-letters>
					{meetHeadlineLines.map((line) => (
						<span class="hline">
							{line.flatMap((word, i) => {
								const w = (
									<span class="word-w">
										{Array.from(word).map((ch) => (
											<span class="char">{ch}</span>
										))}
									</span>
								);
								return i > 0 ? [" ", w] : [w];
							})}
						</span>
					))}
				</h2>
				<ul class="cares">
					{cares.map((c) => (
						<li><span>{c}</span></li>
					))}
				</ul>
			</div>

			<!-- Scene 2 — closer. Two explicit lines: white statement,
			     orange call. Letters reveal one-at-a-time on scroll. -->
			<div class="scene closer" data-scene="1">
				<h2 class="scene-h xl letters" data-letters>
					{closerLines.map((line) => (
						<span class="hline">
							{line.flatMap((word, i) => {
								const w = (
									<span class={`word-w${word.emph ? " ital" : ""}`}>
										{Array.from(word.text).map((ch) => (
											<span class="char">{ch}</span>
										))}
									</span>
								);
								return i > 0 ? [" ", w] : [w];
							})}
						</span>
					))}
				</h2>
			</div>

			<!-- Single continuous orange bridge line — anchored in story-inner
			     (matches the old version's behavior). Stays fixed in viewport
			     position; only its height is scroll-driven, so it "draws"
			     downward as the transition progresses. -->
			<span class="story-line" data-story-line aria-hidden="true"></span>
		</div>
	</div>
</section>

<!-- Bottom-pad strip: extends the dark teal background after the story
     pin releases, giving the closer headline visible breathing room
     before the next (paper-background) section appears. -->
<div class="story-tail" aria-hidden="true"></div>

<style>
	.story {
		/* Scroll is distributed across scenes by JS (weighted). */
		position: relative;
		background: var(--teal-ink);
		color: var(--paper);
		/* Two scenes — each gets ~150vh of scroll room. Overridden on mobile. */
		height: 320vh;
		isolation: isolate;
	}

	.story::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				ellipse 60% 50% at 18% 22%,
				rgba(20, 124, 145, 0.45) 0%,
				transparent 60%
			),
			radial-gradient(
				ellipse 55% 45% at 85% 78%,
				rgba(252, 182, 38, 0.16) 0%,
				transparent 65%
			),
			radial-gradient(
				ellipse 70% 60% at 50% 50%,
				rgba(247, 128, 64, 0.08) 0%,
				transparent 70%
			);
		pointer-events: none;
		z-index: 0;
	}

	.story::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image: radial-gradient(
			circle at 1px 1px,
			rgba(255, 255, 255, 0.06) 1px,
			transparent 0
		);
		background-size: 32px 32px;
		mask-image: linear-gradient(180deg, transparent 0%, #000 22%, #000 78%, transparent 100%);
		-webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 22%, #000 78%, transparent 100%);
		pointer-events: none;
		z-index: 0;
	}

	.story-pin {
		position: sticky;
		top: 0;
		height: 100vh;
		display: grid;
		place-items: center;
		overflow: hidden;
		z-index: 1;
	}

	.story-inner {
		position: relative;
		width: 100%;
		max-width: var(--max-w);
		padding-inline: var(--gutter);
		text-align: center;
		min-height: 100vh;
		display: grid;
		place-items: center;
	}

	/* Scenes stack on top of each other in the pinned viewport. They don't
	   fade — JS translates them up/down in a "filmstrip" tied 1:1 to scroll
	   so they slide like a real page scroll, not crossfade. */
	.scene {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: clamp(14px, 1.6vw, 22px);
		padding: clamp(40px, 8vh, 80px) clamp(20px, 5vw, 60px);
		will-change: transform;
		pointer-events: none;
	}
	/* Initial filmstrip positions: Meet centered, Line + Closer below the
	   viewport — JS adjusts translateY per scroll frame. */
	.scene[data-scene="0"] { transform: translateY(0); }
	.scene[data-scene="1"] { transform: translateY(100vh); }
	.scene.is-active { pointer-events: auto; }

	/* Eyebrow */
	.kicker {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 0.78rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--gold);
		margin: 0;
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 550ms cubic-bezier(0.22, 0.61, 0.36, 1),
			transform 550ms cubic-bezier(0.22, 0.61, 0.36, 1);
	}
	.kicker.is-shown {
		opacity: 0.9;
		transform: none;
	}
	/* Meet headline collapses to zero height before reveal so the kicker
	   sits centered ALONE first. When the headline expands, the flex
	   centering reflows and the kicker naturally shifts up. */
	.scene.meet .scene-h {
		max-height: 0;
		opacity: 0;
		overflow: hidden;
		transition:
			max-height 700ms cubic-bezier(0.22, 0.61, 0.36, 1),
			opacity 500ms cubic-bezier(0.22, 0.61, 0.36, 1);
	}
	.scene.meet .scene-h.is-shown {
		max-height: 60vh;
		opacity: 1;
	}

	.scene-h {
		font-family: var(--font-sans);
		font-weight: 700;
		letter-spacing: -0.028em;
		line-height: 1.08;
		color: var(--paper);
		font-size: clamp(34px, 5vw, 72px);
		margin: 0;
		max-width: 26ch;
		text-wrap: balance;
		/* Small bottom padding so descenders ("g", "p", etc.) aren't
		   clipped by the overflow-hidden max-height collapse trick. */
		padding-bottom: 0.15em;
	}
	.scene-h.xl {
		font-size: clamp(44px, 6.8vw, 104px);
		max-width: 16ch;
	}
	.scene-h .ital {
		color: var(--orange);
	}
	/* Explicit line break inside a headline split into [word, word, ...] lines. */
	.scene-h .hline {
		display: block;
	}

	/* "Cares" list — each item collapses to zero height when hidden so
	   the kicker + headline naturally sit at the scene's center until the
	   cares scroll in. As each one expands, the flex layout reflows and
	   the headline shifts up smoothly to make room. */
	.cares {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		/* No flex gap — spacing comes from each item's padding-top so the
		   gap collapses to 0 along with the item when hidden. */
		gap: 0;
		max-width: 60ch;
		text-align: center;
	}
	.cares li {
		font-family: var(--font-sans);
		font-weight: 600;
		letter-spacing: -0.018em;
		line-height: 1.3;
		font-size: clamp(20px, 2.2vw, 30px);
		padding-top: clamp(12px, 1.6vw, 22px);
		opacity: 0;
		max-height: 0;
		overflow: hidden;
		transform: translateY(12px);
		transition:
			opacity 600ms cubic-bezier(0.22, 0.61, 0.36, 1),
			max-height 600ms cubic-bezier(0.22, 0.61, 0.36, 1),
			padding-top 600ms cubic-bezier(0.22, 0.61, 0.36, 1),
			transform 600ms cubic-bezier(0.22, 0.61, 0.36, 1);
	}
	.cares li:first-child {
		padding-top: 0;
	}
	.cares li.is-shown {
		opacity: 1;
		/* Generous max — sized for the longest care wrapped across 2 lines. */
		max-height: 240px;
		transform: none;
	}
	.cares li:nth-child(1) span { color: var(--paper); }
	.cares li:nth-child(2) span { color: var(--gold); }
	.cares li:nth-child(3) span { color: var(--orange); }
	.cares li.is-shown {
		opacity: 1;
		transform: none;
	}

	/* Closer scene — top-aligned with padding so the headline lands BELOW
	   the bridge line (which extends from 22vh to ~42vh). */
	.scene.closer {
		gap: clamp(10px, 1.6vh, 20px);
		justify-content: flex-start;
		padding-top: 50vh;
	}
	/* Top line of the closer headline is noticeably smaller than the
	   orange call below it, so "Let's do this." reads as the louder
	   call to action. */
	.scene.closer .scene-h .hline:first-child {
		font-size: clamp(26px, 3.4vw, 52px);
		font-weight: 600;
	}
	.letters {
		max-width: 18ch;
	}
	/* Each word stays intact (inline-block); spaces between words are real
	   text nodes, so the headline wraps at word boundaries. */
	.word-w {
		display: inline-block;
		white-space: nowrap;
	}
	.word-w.ital {
		color: var(--orange);
	}
	.char {
		display: inline-block;
		opacity: 0;
		transition: opacity 220ms ease;
	}
	.char.is-shown {
		opacity: 1;
	}

	/* Single continuous line — anchored in story-inner, top is fixed in
	   the viewport so it never moves; only its height is scroll-driven.
	   Identical behavior to the old Story version. Max height = 20vh,
	   line bottom lands at 22vh + 20vh = 42vh (with 8vh of room before
	   the closer headline at center). */
	.story-line {
		position: absolute;
		top: 22vh;
		left: 50%;
		transform: translateX(-50%);
		width: 2px;
		height: 0;
		background: var(--orange);
		border-radius: 2px;
		box-shadow: 0 0 16px rgba(247, 128, 64, 0.42);
		transform-origin: top center;
		z-index: 5;
		/* Small smoothing transition takes the edge off sub-pixel jitter
		   between scroll frames without lagging behind the scrollbar. */
		transition: height 60ms linear;
		pointer-events: none;
	}

	/* Dark teal spacers framing the section so the paper→teal→paper
	   transitions have breathing room. */
	.story-head {
		height: clamp(72px, 9vw, 120px);
		background: var(--teal-ink);
	}
	.story-tail {
		height: clamp(80px, 10vw, 140px);
		background: var(--teal-ink);
	}

	/* Mobile fallback — no pinning, scenes flow vertically */
	@media (max-width: 720px) {
		.story {
			height: auto;
			padding: clamp(80px, 14vw, 140px) 0;
		}
		.story-pin {
			position: relative;
			height: auto;
			display: block;
		}
		.story-inner {
			min-height: 0;
			display: block;
			text-align: left;
		}
		.scene {
			position: relative;
			inset: auto;
			min-height: 0;
			padding: 0 0 clamp(56px, 12vw, 96px);
			align-items: flex-start;
			justify-content: flex-start;
			gap: 14px;
			opacity: 0;
			transform: translateY(28px);
			filter: none;
		}
		.scene.in-view {
			opacity: 1;
			transform: none;
		}
		.scene-h, .scene-h.xl {
			text-align: left;
			max-width: none;
		}
		.cares { max-width: none; text-align: left; }
		.cares li, .cares li.is-shown { opacity: 1; transform: none; }
		.char, .char.is-shown { opacity: 1; }
		.kicker, .kicker.is-shown { opacity: 0.9; transform: none; }
		.scene.meet .scene-h,
		.scene.meet .scene-h.is-shown {
			opacity: 1;
			max-height: none;
			overflow: visible;
			transform: none;
		}
		.cares li, .cares li.is-shown {
			max-height: none;
			overflow: visible;
		}
		.story-line { display: none; }
	}

	@media (prefers-reduced-motion: reduce) {
		.scene,
		.scene.is-past,
		.cares li,
		.char {
			transition: none;
		}
		.char { opacity: 1; }
		.cares li { opacity: 1; transform: none; }
		.kicker { opacity: 0.9; transform: none; }
		.scene.meet .scene-h {
			opacity: 1;
			max-height: none;
			overflow: visible;
			transform: none;
		}
		.cares li {
			max-height: none;
			overflow: visible;
		}
		.story-line { display: none; }
		.scene {
			opacity: 1;
			transform: none;
			filter: none;
			position: relative;
			inset: auto;
			padding: 0 0 80px;
		}
		.story {
			height: auto;
		}
		.story-pin {
			position: relative;
			height: auto;
			display: block;
		}
		.story-inner { min-height: 0; display: block; }
	}
</style>

<script>
	const section = document.querySelector<HTMLElement>("[data-story]");
	const scenes = section
		? Array.from(section.querySelectorAll<HTMLElement>(".scene"))
		: [];
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const isSmall = window.matchMedia("(max-width: 720px)").matches;

	if (section && scenes.length && !reduce && !isSmall) {
		// 2-slot filmstrip:
		//   slot 0 = Meet (cares stagger here)
		//   slot 1 = Closer (line grows above it as it rises, letters reveal once centered)
		//
		// Phases:
		//   0.00 – 0.45  PAUSE @ Meet — kicker stays alone, then headline
		//                expands, then cares stagger in with breathing room
		//                between each so it doesn't feel rapid-fire.
		//   0.45 – 0.75  SLIDE — Meet exits up; closer + its child line slide
		//                up together; line height grows from 0 to full at the
		//                same rate, so the line draws in as the closer rises.
		//   0.75 – 1.00  PAUSE @ Closer — letters reveal
		const P_PAUSE_END = 0.45;
		const P_SLIDE_END = 0.75;

		const meetScene = scenes[0];
		const closerScene = scenes[1];
		const storyLine = section.querySelector<HTMLElement>("[data-story-line]");
		// Matches old version: max 20vh, capped at 180px.
		const lineMaxH = () => Math.min(180, Math.round(window.innerHeight * 0.20));

		let raf = 0;

		const update = () => {
			raf = 0;
			const rect = section.getBoundingClientRect();
			const scrollable = section.offsetHeight - window.innerHeight;
			if (scrollable <= 0) return;
			const traveled = Math.max(0, Math.min(scrollable, -rect.top));
			const progress = traveled / scrollable;

			// Slide offset: 0 (Meet centered) → 1 (Closer centered).
			let offset = 0;
			if (progress < P_PAUSE_END) {
				offset = 0;
			} else if (progress < P_SLIDE_END) {
				offset = (progress - P_PAUSE_END) / (P_SLIDE_END - P_PAUSE_END);
			} else {
				offset = 1;
			}

			const vh = window.innerHeight;
			// Meet slides up out of view; Closer slides up from below into view.
			if (meetScene)   meetScene.style.transform   = `translateY(${-offset * vh}px)`;
			if (closerScene) closerScene.style.transform = `translateY(${(1 - offset) * vh}px)`;
			// Bridge line — anchored at top:22vh in story-inner (matches old
			// version). Hidden during Meet pause, draws downward during the
			// slide transition, stays at full height during Closer pause.
			if (storyLine) storyLine.style.height = `${offset * lineMaxH()}px`;

			// Pointer-events: meet active in pause phase 1, closer active in pause phase 2.
			scenes.forEach((s, i) => {
				const isActive = (i === 0 && offset < 0.5) || (i === 1 && offset >= 0.5);
				s.classList.toggle("is-active", isActive);
			});

			// Sequential reveal across Phase 1 (Meet centered):
			//   1) MEET CWS kicker alone in the center
			//   2) Headline expands (kicker shifts up via flex re-centering)
			//      and reveals letter-by-letter on scroll
			//   3) Cares appear one by one, headline shifts up further
			if (meetScene) {
				const local = Math.min(1, progress / P_PAUSE_END);
				const kicker = meetScene.querySelector<HTMLElement>(".kicker");
				const headline = meetScene.querySelector<HTMLElement>(".scene-h");
				if (kicker) kicker.classList.toggle("is-shown", local >= 0.03);

				// MEET CWS holds alone until well into the phase — headline
				// expansion is held back so the eyebrow has real space to breathe.
				const hExpand = 0.30;
				const hStart = 0.32, hEnd = 0.50;
				if (headline) headline.classList.toggle("is-shown", local >= hExpand);

				const meetChars = meetScene.querySelectorAll<HTMLElement>(".char");
				const hSpan = hEnd - hStart;
				const hTotal = Math.max(1, meetChars.length - 1);
				meetChars.forEach((el, idx) => {
					const t = hStart + (idx / hTotal) * hSpan;
					el.classList.toggle("is-shown", local >= t);
				});

				// Cares stagger with a generous gap between each so the reader
				// has time to read one before the next arrives.
				const items = meetScene.querySelectorAll<HTMLElement>(".cares li");
				const careThresholds = [0.62, 0.78, 0.94];
				items.forEach((item, idx) => {
					item.classList.toggle("is-shown", local >= (careThresholds[idx] ?? 0));
				});
			}

			// Closer letters: reveal during pause phase 2 (Closer centered).
			if (closerScene) {
				const chars = closerScene.querySelectorAll<HTMLElement>(".char");
				if (progress < P_SLIDE_END) {
					chars.forEach((c) => c.classList.remove("is-shown"));
				} else {
					const local = (progress - P_SLIDE_END) / (1 - P_SLIDE_END);
					const startT = 0.05, endT = 0.80;
					const span = endT - startT;
					const total = Math.max(1, chars.length - 1);
					chars.forEach((el, idx) => {
						const t = startT + (idx / total) * span;
						el.classList.toggle("is-shown", local >= t);
					});
				}
			}
		};

		const onScroll = () => {
			if (!raf) raf = requestAnimationFrame(update);
		};
		window.addEventListener("scroll", onScroll, { passive: true });
		window.addEventListener("resize", onScroll, { passive: true });
		update();
	} else if (section && scenes.length) {
		// Mobile / reduced motion — reveal each scene as it enters viewport.
		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						e.target.classList.add("in-view");
						io.unobserve(e.target);
					}
				}
			},
			{ threshold: 0.18, rootMargin: "0px 0px -60px 0px" }
		);
		scenes.forEach((s) => io.observe(s));
	}
</script>

---
// Client logos from /public/logos/ (sourced from the project's `logos/`
// folder). Placeholder mapping — swap as the real client→reviewer
// mapping is confirmed.
const reviews = [
	{
		name: "Aron Rosenblum",
		meta: "10 reviews",
		when: "a year ago",
		stars: 5,
		logo: "/logos/admire-aba.png",
		body: "To say that CWS is a 5 star rated company is an understatement, CWS is a 10 star rated company. The team at CWS is unparalleled. They own your project from start to finish and don't settle until every detail is satisfactory. They are patient and understand your needs. Their craftsmanship is stellar. Thank you to Martin and the entire team for your help. I am thrilled with my website.",
	},
	{
		name: "Mordechai Babad",
		meta: "5 reviews",
		when: "2 months ago",
		stars: 5,
		logo: "/logos/everest-aba.png",
		body: "Working with Martin and the entire CWS team was hands down one of the best decisions I made for my business. The quality of work is top-tier, they move fast, and they actually listen! Anytime I needed something adjusted, it was handled immediately. No drama, no excuses. Very professional. Highly recommend!",
	},
	{
		name: "Issac Cziment",
		meta: "Local Guide · 36 reviews · 29 photos",
		when: "5 months ago",
		stars: 5,
		logo: "/logos/evolve-aba.png",
		body: "I couldn't be happier with the web design team that built the Kennedy ABA website! From day one, they really listened to my ideas and understood my goals. Their attention to detail is amazing, and they were so accommodating throughout the process, always willing to make adjustments and bring my vision to life.",
	},
	{
		name: "Asher Ordentlich",
		meta: "1 review",
		when: "6 months ago",
		stars: 5,
		logo: "/logos/gradual-bh.png",
		body: "Creative web services designed a website for us that went above and beyond anything we could have expected. The service was top notch, very friendly and they were eager to please. If you are looking for a website that is unique and user friendly, creative web services will be the perfect place to reach out to!",
	},
	{
		name: "Yoel Gold",
		meta: "2 reviews",
		when: "3 years ago",
		stars: 5,
		logo: "/logos/logo-dark.png",
		body: "Martin and his team built us a state of the art, customized website that caters to the very specific needs of our organization. The customer service is second to none. Martin's ongoing care and continued availability, always ensuring that every detail of the website operates at the highest level for each campaign, makes him and his team my number one recommendation!",
	},
];
---

<section id="testimonials" class="reviews">
	<div class="wrap reviews-grid">
		<aside class="reviews-aside reveal">
			<h2 class="display reviews-title">
				Service like that<br />
				<span class="ital">gets reviews like these.</span>
			</h2>
			<p class="reviews-sub">
				<strong>TLDR;</strong> Our clients love the product <em>and</em> the process.
			</p>

			<a
				class="rating-card"
				href="https://www.google.com/search?safe=strict&sca_esv=ce94e24e788b5151&sxsrf=ANbL-n5oo-DU5KlcYZYVgj0kh6tan_AX3w:1779274638654&si=AL3DRZEsmMGCryMMFSHJ3StBhOdZ2-6yYkXd_doETEE1OR-qOUK9fkQM8auJMKkWPrBhk8W3CoOYWmX-poGep_mAnX-GUkc4eyu5f1okFAn9Zpg_0wYFBmQqPGXp4kFPnODlBHuuKegnUSGEhg6BfQo71rAZBv-A1Q%3D%3D&q=Creative+Web+Services+Reviews&sa=X&ved=2ahUKEwjcza3G2seUAxU1UUEAHeywE_QQ0bkNegQIMxAF&biw=1536&bih=791&dpr=1.25"
				target="_blank"
				rel="noopener"
				aria-label="See our Google reviews — 5.0 stars, 80+ reviews"
			>
				<div class="rating-row">
					<div class="g-mark" aria-hidden="true">G</div>
					<div class="rating-text">
						<span class="rating-num">5.0</span>
						<span class="stars">
							{[0, 1, 2, 3, 4].map(() => (
								<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
									<path
										d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"
										fill="currentColor"
									></path>
								</svg>
							))}
						</span>
						<span class="rating-meta">Google · 80+ reviews</span>
					</div>
				</div>
			</a>
		</aside>

		<div class="stack">
			{
				reviews.map((r, i) => (
					<article class="card" data-idx={i}>
						<header class="card-head">
							<div class="meta">
								<div class="card-stars">
									{Array.from({ length: r.stars }).map(() => (
										<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
											<path
												d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"
												fill="currentColor"
											></path>
										</svg>
									))}
								</div>
								<div class="who">{r.name}</div>
								<div class="when">{r.meta} · {r.when}</div>
							</div>
							<div class="avatar" aria-hidden="true">
								<img src={r.logo} alt="" loading="lazy" decoding="async" />
							</div>
						</header>
						<p class="body">{r.body}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.reviews {
		padding: clamp(72px, 10vw, 140px) 0;
		background: linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%);
		position: relative;
	}

	.reviews-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
		gap: clamp(32px, 5vw, 80px);
		align-items: start;
	}

	@media (max-width: 880px) {
		.reviews-grid { grid-template-columns: 1fr; }
	}

	.reviews-aside {
		position: sticky;
		top: 96px;
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	@media (max-width: 880px) {
		.reviews-aside { position: static; }
	}

	.reviews-title {
		font-size: clamp(36px, 4.6vw, 64px);
		margin: 6px 0 0;
	}
	.reviews-title .ital {
		color: var(--teal);
	}

	.reviews-sub {
		font-size: clamp(14px, 1vw, 16px);
		color: var(--ink-mute);
		margin: 0;
		max-width: 380px;
	}
	.reviews-sub strong {
		font-weight: 700;
		color: var(--teal-ink);
		letter-spacing: 0.04em;
	}
	.reviews-sub em {
		font-style: italic;
		color: var(--orange);
		font-weight: 600;
	}

	.rating-card {
		margin-top: 12px;
		padding: 18px 20px;
		background: #fff;
		border: 1px solid var(--hairline);
		border-radius: 18px;
		display: flex;
		flex-direction: column;
		gap: 8px;
		max-width: 320px;
		box-shadow: 0 14px 40px -28px rgba(8, 43, 54, 0.4);
		color: inherit;
		text-decoration: none;
		transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.1, 1),
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}
	.rating-card:hover {
		transform: translateY(-2px);
		border-color: var(--hairline-strong);
		box-shadow: 0 22px 50px -28px rgba(8, 43, 54, 0.5);
	}
	.rating-row {
		display: flex;
		gap: 14px;
		align-items: center;
	}
	.g-mark {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: var(--orange);
		color: #fff;
		display: grid;
		place-items: center;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 1.4rem;
		flex-shrink: 0;
	}
	.rating-text {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 6px 10px;
	}
	.rating-num {
		font-weight: 900;
		font-size: 1.4rem;
		letter-spacing: -0.03em;
		color: var(--teal-ink);
		line-height: 1;
	}
	.rating-text .stars {
		color: var(--gold);
		display: inline-flex;
		gap: 1px;
	}
	.rating-meta {
		flex-basis: 100%;
		color: var(--ink-mute);
		font-size: 0.82rem;
	}

	.stack {
		display: flex;
		flex-direction: column;
		gap: 28px;
		padding-bottom: 80px;
	}

	.card {
		position: sticky;
		top: 120px;
		background: #fff;
		border: 1px solid var(--hairline);
		border-radius: 24px;
		padding: 28px 30px 30px;
		box-shadow: 0 24px 60px -36px rgba(8, 43, 54, 0.4);
		transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.1, 1);
	}
	.card[data-idx="0"] { top: 120px; transform: rotate(-0.6deg); }
	.card[data-idx="1"] { top: 140px; transform: rotate(0.4deg); }
	.card[data-idx="2"] { top: 160px; transform: rotate(-0.3deg); }
	.card[data-idx="3"] { top: 180px; transform: rotate(0.5deg); }
	.card[data-idx="4"] { top: 200px; transform: rotate(-0.2deg); }

	@media (max-width: 880px) {
		.card { position: static; transform: none !important; }
	}

	.card:hover {
		transform: rotate(0deg) translateY(-2px) !important;
	}

	.card-head {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 14px;
		padding-bottom: 14px;
		border-bottom: 1px solid var(--hairline);
	}
	.avatar {
		display: inline-flex;
		align-items: center;
		height: 36px;
		max-width: 96px;
		flex-shrink: 0;
	}
	.avatar img {
		height: 100%;
		width: auto;
		max-width: 100%;
		object-fit: contain;
		display: block;
	}
	.meta {
		display: flex;
		flex-direction: column;
		gap: 1px;
		flex: 1;
	}
	.who {
		font-weight: 700;
		color: var(--teal-ink);
		font-size: 0.96rem;
	}
	.when {
		font-size: 0.78rem;
		color: var(--ink-mute);
	}
	.card-stars {
		color: var(--gold);
		display: inline-flex;
		gap: 1px;
		margin-bottom: 4px;
	}

	.body {
		font-size: clamp(15px, 1.05vw, 17px);
		line-height: 1.6;
		color: var(--ink);
		margin: 0;
	}
</style>

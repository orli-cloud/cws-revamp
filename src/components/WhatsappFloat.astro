---
const whatsappNumber = ""; // Set the number here e.g. "15551234567"
const wameUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent("Hi Martin, I'd like to chat about a project.")}`;
---

<div class="wa" data-wa>
	<div class="wa-popup" data-wa-popup role="dialog" aria-label="Chat with Martin on WhatsApp" aria-hidden="true">
		<header class="wa-head">
			<div class="wa-avatar">
				<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
					<path
						d="M20.52 3.48A11.93 11.93 0 0 0 12.05 0C5.42 0 .03 5.39.03 12c0 2.12.55 4.18 1.6 6L0 24l6.18-1.62a12 12 0 0 0 5.87 1.5h.01c6.62 0 12.01-5.39 12.01-12 0-3.21-1.25-6.22-3.55-8.4ZM12.06 21.78h-.01a9.78 9.78 0 0 1-4.99-1.37l-.36-.21-3.67.96.98-3.58-.23-.37a9.74 9.74 0 0 1-1.5-5.21c0-5.39 4.39-9.78 9.78-9.78 2.61 0 5.07 1.02 6.92 2.87a9.71 9.71 0 0 1 2.86 6.92c0 5.39-4.39 9.78-9.78 9.78Zm5.36-7.32c-.29-.15-1.74-.86-2.01-.96-.27-.1-.47-.15-.66.15-.2.29-.76.96-.93 1.16-.17.2-.34.22-.63.07-.29-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.03-.17-.29-.02-.45.13-.6.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.66-1.59-.91-2.18-.24-.57-.48-.49-.66-.5-.17-.01-.37-.01-.56-.01-.2 0-.51.07-.78.37-.27.29-1.02 1-1.02 2.44 0 1.44 1.05 2.83 1.2 3.03.15.2 2.07 3.16 5.02 4.43.7.3 1.25.48 1.68.62.7.22 1.34.19 1.85.12.56-.08 1.74-.71 1.99-1.4.25-.69.25-1.27.17-1.4-.07-.13-.27-.2-.56-.34Z"
						fill="currentColor"
					></path>
				</svg>
			</div>
			<div class="wa-meta">
				<div class="wa-who">Martin · CWS</div>
				<div class="wa-status">
					<span class="wa-dot"></span>
					Usually replies within an hour
				</div>
			</div>
			<button class="wa-close" data-wa-close type="button" aria-label="Close chat">
				<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
					<path
						d="M6 6l12 12M18 6L6 18"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
					></path>
				</svg>
			</button>
		</header>

		<div class="wa-body">
			<div class="wa-bubble">
				<p>Hi 👋 Got a project in mind?</p>
				<p>Drop a quick message and we'll take it from there.</p>
				<span class="wa-time">just now</span>
			</div>
		</div>

		<a href={wameUrl} target="_blank" rel="noopener" class="wa-cta">
			<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
				<path
					d="M20.52 3.48A11.93 11.93 0 0 0 12.05 0C5.42 0 .03 5.39.03 12c0 2.12.55 4.18 1.6 6L0 24l6.18-1.62a12 12 0 0 0 5.87 1.5h.01c6.62 0 12.01-5.39 12.01-12 0-3.21-1.25-6.22-3.55-8.4Z"
					fill="currentColor"
				></path>
			</svg>
			Start chat on WhatsApp
		</a>
	</div>

	<button class="wa-button" data-wa-toggle type="button" aria-label="Open WhatsApp chat">
		<span class="wa-pulse"></span>
		<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
			<path
				d="M20.52 3.48A11.93 11.93 0 0 0 12.05 0C5.42 0 .03 5.39.03 12c0 2.12.55 4.18 1.6 6L0 24l6.18-1.62a12 12 0 0 0 5.87 1.5h.01c6.62 0 12.01-5.39 12.01-12 0-3.21-1.25-6.22-3.55-8.4ZM12.06 21.78h-.01a9.78 9.78 0 0 1-4.99-1.37l-.36-.21-3.67.96.98-3.58-.23-.37a9.74 9.74 0 0 1-1.5-5.21c0-5.39 4.39-9.78 9.78-9.78 2.61 0 5.07 1.02 6.92 2.87a9.71 9.71 0 0 1 2.86 6.92c0 5.39-4.39 9.78-9.78 9.78Zm5.36-7.32c-.29-.15-1.74-.86-2.01-.96-.27-.1-.47-.15-.66.15-.2.29-.76.96-.93 1.16-.17.2-.34.22-.63.07-.29-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.03-.17-.29-.02-.45.13-.6.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.66-1.59-.91-2.18-.24-.57-.48-.49-.66-.5-.17-.01-.37-.01-.56-.01-.2 0-.51.07-.78.37-.27.29-1.02 1-1.02 2.44 0 1.44 1.05 2.83 1.2 3.03.15.2 2.07 3.16 5.02 4.43.7.3 1.25.48 1.68.62.7.22 1.34.19 1.85.12.56-.08 1.74-.71 1.99-1.4.25-.69.25-1.27.17-1.4-.07-.13-.27-.2-.56-.34Z"
				fill="currentColor"
			></path>
		</svg>
	</button>
</div>

<style>
	.wa {
		position: fixed;
		bottom: 24px;
		right: 24px;
		z-index: 70;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 14px;
		font-family: var(--font-sans);
	}

	.wa-button {
		position: relative;
		width: 60px;
		height: 60px;
		border: none;
		border-radius: 50%;
		background: #25d366;
		color: #fff;
		display: grid;
		place-items: center;
		cursor: pointer;
		box-shadow:
			0 14px 28px -10px rgba(37, 211, 102, 0.55),
			0 6px 14px -4px rgba(0, 0, 0, 0.18);
		transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
	}
	.wa-button:hover {
		transform: scale(1.06) rotate(-6deg);
		box-shadow:
			0 18px 36px -12px rgba(37, 211, 102, 0.65),
			0 8px 18px -6px rgba(0, 0, 0, 0.2);
	}
	.wa-button:active { transform: scale(0.96); }

	.wa-pulse {
		position: absolute;
		inset: -4px;
		border-radius: 50%;
		background: #25d366;
		opacity: 0.4;
		animation: wa-pulse 2.4s ease-out infinite;
		z-index: -1;
	}
	@keyframes wa-pulse {
		0% { transform: scale(0.95); opacity: 0.45; }
		70% { transform: scale(1.55); opacity: 0; }
		100% { transform: scale(1.55); opacity: 0; }
	}

	.wa-popup {
		width: 320px;
		max-width: calc(100vw - 48px);
		background: #fff;
		border-radius: 18px;
		overflow: hidden;
		box-shadow:
			0 24px 60px -20px rgba(8, 43, 54, 0.35),
			0 6px 16px -8px rgba(0, 0, 0, 0.15);
		transform: translateY(12px) scale(0.95);
		transform-origin: bottom right;
		opacity: 0;
		pointer-events: none;
		transition:
			transform 0.35s cubic-bezier(0.34, 1.4, 0.64, 1),
			opacity 0.25s ease;
		border: 1px solid var(--hairline);
	}
	.wa.is-open .wa-popup {
		transform: translateY(0) scale(1);
		opacity: 1;
		pointer-events: auto;
	}

	.wa-head {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 14px 14px 14px 16px;
		background: #128c7e;
		color: #fff;
	}
	.wa-avatar {
		width: 38px;
		height: 38px;
		border-radius: 50%;
		background: #25d366;
		display: grid;
		place-items: center;
		flex-shrink: 0;
	}
	.wa-meta { flex: 1; min-width: 0; }
	.wa-who {
		font-weight: 700;
		font-size: 0.92rem;
		letter-spacing: -0.005em;
		line-height: 1.15;
	}
	.wa-status {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 0.74rem;
		opacity: 0.9;
		margin-top: 2px;
	}
	.wa-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 0 2px rgba(74, 222, 128, 0.25);
	}
	.wa-close {
		width: 28px;
		height: 28px;
		border: none;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.18);
		color: #fff;
		display: grid;
		place-items: center;
		cursor: pointer;
		transition: background 0.2s ease;
	}
	.wa-close:hover { background: rgba(255, 255, 255, 0.28); }

	.wa-body {
		padding: 18px 16px 14px;
		background-color: #e5ddd5;
		background-image:
			radial-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 0),
			linear-gradient(180deg, #ece5dd 0%, #efe7dc 100%);
		background-size: 14px 14px, 100% 100%;
		min-height: 130px;
	}
	.wa-bubble {
		position: relative;
		display: inline-block;
		max-width: 88%;
		padding: 10px 14px 18px;
		background: #fff;
		border-radius: 12px;
		border-top-left-radius: 4px;
		font-size: 0.88rem;
		color: #0e1a1f;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
		animation: wa-bubble-in 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) 0.15s both;
	}
	.wa-bubble p {
		margin: 0;
		line-height: 1.4;
	}
	.wa-bubble p + p { margin-top: 6px; }
	.wa-bubble::before {
		content: "";
		position: absolute;
		top: 0;
		left: -7px;
		width: 0;
		height: 0;
		border: 7px solid transparent;
		border-top-color: #fff;
		border-right-color: #fff;
	}
	.wa-time {
		position: absolute;
		bottom: 5px;
		right: 8px;
		font-size: 0.62rem;
		color: #888;
	}
	@keyframes wa-bubble-in {
		from { opacity: 0; transform: translateY(6px) scale(0.96); }
		to { opacity: 1; transform: none; }
	}

	.wa-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 14px 18px;
		background: #25d366;
		color: #fff;
		font-weight: 700;
		font-size: 0.92rem;
		text-decoration: none;
		transition: background 0.2s ease, gap 0.2s ease;
	}
	.wa-cta:hover {
		background: #1faa54;
		gap: 14px;
	}

	@media (max-width: 480px) {
		.wa { bottom: 18px; right: 18px; }
		.wa-button { width: 54px; height: 54px; }
	}
</style>

<script>
	const wa = document.querySelector<HTMLElement>("[data-wa]");
	const toggle = document.querySelector<HTMLElement>("[data-wa-toggle]");
	const close = document.querySelector<HTMLElement>("[data-wa-close]");
	const popup = document.querySelector<HTMLElement>("[data-wa-popup]");

	if (wa && toggle && close && popup) {
		const open = () => {
			wa.classList.add("is-open");
			popup.setAttribute("aria-hidden", "false");
		};
		const shut = () => {
			wa.classList.remove("is-open");
			popup.setAttribute("aria-hidden", "true");
		};

		toggle.addEventListener("click", () => {
			wa.classList.contains("is-open") ? shut() : open();
		});
		close.addEventListener("click", shut);

		// Close on Escape or click outside
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && wa.classList.contains("is-open")) shut();
		});
		document.addEventListener("click", (e) => {
			if (!wa.contains(e.target as Node) && wa.classList.contains("is-open")) shut();
		});
	}
</script>

---
// Milkshake-style reveal footer: pinned full-viewport behind the page
// (see .site-footer / .page-shell rules in Layout.astro). The content
// above scrolls up over it like a curtain lifting.
const nav = [
	{ label: "Work", href: "#work" },
	{ label: "Services", href: "#services" },
	{ label: "Why us", href: "#why" },
	{ label: "Reviews", href: "#testimonials" },
	{ label: "Contact", href: "#contact" },
];
const year = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Site footer">
	<div class="foot-frame wrap">
		<!-- Top: logo left, big nav right -->
		<div class="foot-top">
			<a href="/" class="foot-logo" aria-label="Creative Web Services — home">
				<img src="/cws-logo-real.svg" alt="Creative Web Services" />
			</a>

			<nav class="foot-nav" aria-label="Footer">
				{
					nav.map((l) => (
						<a href={l.href} class="foot-nav-link">
							<span class="link-inner">
								<span>{l.label}</span>
								<span>{l.label}</span>
							</span>
						</a>
					))
				}
			</nav>
		</div>

		<!-- Giant contact CTA -->
		<a href="mailto:hello@cwsio.com" class="foot-cta">
			<span class="foot-cta-text">Let's talk</span>
			<span class="foot-cta-arrow" aria-hidden="true">
				<svg viewBox="0 0 198.26 198.26" width="100%" height="100%" fill="currentColor">
					<path
						d="M107.92,90.34l.38,92.19c.04,8.69,7.17,15.76,15.86,15.73l58.37-.24c8.69-.04,15.76-7.17,15.73-15.86l-.65-155.04.04-10.57c.02-4.39-1.79-8.38-4.69-11.26-2.88-2.9-6.87-4.71-11.26-4.69l-10.58.04L16.1,0C7.42-.04.28,7.04.24,15.73L0,74.09c-.04,8.69,7.04,15.82,15.73,15.86l92.19.38Z"
					></path>
				</svg>
			</span>
		</a>

		<div class="foot-rule" aria-hidden="true"></div>

		<!-- Bottom info row -->
		<div class="foot-bottom">
			<div class="foot-col">
				<span class="foot-col-h">Social</span>
				<a href="https://instagram.com/" target="_blank" rel="noopener">
					<span class="link-inner"><span>Instagram</span><span>Instagram</span></span>
				</a>
				<a href="https://linkedin.com/" target="_blank" rel="noopener">
					<span class="link-inner"><span>LinkedIn</span><span>LinkedIn</span></span>
				</a>
			</div>

			<div class="foot-col">
				<span class="foot-col-h">Contact</span>
				<a href="mailto:hello@cwsio.com">
					<span class="link-inner"><span>hello@cwsio.com</span><span>hello@cwsio.com</span></span>
				</a>
				<a href="https://wa.me/" target="_blank" rel="noopener">
					<span class="link-inner"><span>Whatsapp Martin</span><span>Whatsapp Martin</span></span>
				</a>
			</div>

			<div class="foot-meta">
				<span class="foot-legal">© {year} Creative Web Services LLC.</span>
			</div>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--paper);
		color: var(--teal-ink);
		overflow: hidden;
		isolation: isolate;
	}
	/* Soft brand glow so the reveal has depth */
	.site-footer::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 82% 8%, color-mix(in srgb, var(--gold) 14%, transparent) 0%, transparent 48%),
			radial-gradient(ellipse at 10% 92%, color-mix(in srgb, var(--teal) 12%, transparent) 0%, transparent 52%);
		pointer-events: none;
		z-index: -1;
	}

	.foot-frame {
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: clamp(28px, 5vh, 64px);
		padding-top: clamp(40px, 7vh, 90px);
		padding-bottom: clamp(28px, 5vh, 56px);
	}

	/* Top row */
	.foot-top {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 40px;
	}
	.foot-logo img {
		height: clamp(70px, 11vh, 132px);
		width: auto;
		display: block;
	}

	.foot-nav {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: clamp(12px, 2.6vh, 32px);
		text-align: right;
	}
	.foot-nav-link {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: clamp(26px, 4.4vh, 52px);
		line-height: 1.12;
		letter-spacing: -0.02em;
		color: var(--teal-ink);
		overflow: hidden;
		display: inline-block;
		height: 1.12em;
	}

	/* Giant CTA */
	.foot-cta {
		display: inline-flex;
		align-items: flex-start;
		gap: clamp(10px, 1.4vw, 24px);
		width: fit-content;
		color: var(--teal-ink);
		transition: color 0.35s ease;
	}
	.foot-cta-text {
		font-family: var(--font-sans);
		font-weight: 900;
		font-size: clamp(56px, 13vw, 168px);
		line-height: 0.86;
		letter-spacing: -0.04em;
		text-transform: uppercase;
	}
	.foot-cta-arrow {
		flex-shrink: 0;
		width: clamp(22px, 3vw, 50px);
		height: clamp(22px, 3vw, 50px);
		/* Push the arrow box down so its top lands on the cap line of
		   the text (scales with the text size across viewports). */
		margin-top: calc(clamp(56px, 13vw, 168px) * 0.095);
		color: var(--orange);
		transition: transform 0.4s cubic-bezier(0.34, 1.4, 0.64, 1);
	}
	.foot-cta:hover {
		color: var(--orange);
	}
	.foot-cta:hover .foot-cta-arrow {
		transform: translate(0.12em, -0.06em) scale(1.08);
	}

	/* Divider */
	.foot-rule {
		height: 1px;
		width: 100%;
		background: var(--hairline-strong);
	}

	/* Bottom row */
	.foot-bottom {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: clamp(24px, 5vw, 72px);
		flex-wrap: wrap;
	}
	.foot-col {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.foot-col-h {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 0.72rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--orange);
		margin-bottom: 4px;
	}
	.foot-col a {
		font-size: 1rem;
		font-weight: 500;
		color: var(--teal-ink);
		overflow: hidden;
		display: inline-block;
		line-height: 1.4;
		height: 1.4em;
		width: fit-content;
	}

	/* Shared roll-up link interaction (nav + bottom links) */
	.link-inner {
		display: flex;
		flex-direction: column;
		transition: transform 0.45s cubic-bezier(0.7, 0, 0.2, 1);
	}
	.link-inner > span {
		display: block;
		line-height: 1.12;
	}
	.foot-col .link-inner > span {
		line-height: 1.4;
		height: 1.4em;
	}
	.foot-nav-link .link-inner > span {
		height: 1.12em;
	}
	.link-inner > span:nth-child(2) {
		color: var(--orange);
	}
	/* Two equal stacked spans, so one line up = -50% of the inner */
	.foot-nav-link:hover .link-inner,
	.foot-col a:hover .link-inner {
		transform: translateY(-50%);
	}

	.foot-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 12px;
		text-align: right;
		font-size: 0.84rem;
		color: var(--ink-mute);
		font-weight: 500;
	}
	@media (max-width: 860px) {
		.foot-top {
			flex-direction: column;
			align-items: flex-start;
			gap: clamp(20px, 4vh, 36px);
		}
		.foot-nav {
			align-items: flex-start;
			text-align: left;
			flex-flow: row wrap;
			gap: 6px 22px;
		}
		.foot-nav-link {
			font-size: clamp(22px, 6vw, 34px);
		}
	}

	@media (max-width: 600px) {
		.foot-frame {
			justify-content: space-between;
			gap: 28px;
		}
		.foot-bottom {
			align-items: flex-start;
			gap: 24px;
		}
		.foot-meta {
			align-items: flex-start;
			text-align: left;
		}
	}
</style>

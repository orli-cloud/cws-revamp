---
const cols = [
	{
		title: "Services",
		links: [
			{ label: "Websites", href: "#" },
			{ label: "Brand and logo design", href: "#" },
			{ label: "SEO", href: "#" },
			{ label: "Marketing materials", href: "#" },
			{ label: "Custom systems", href: "#" },
			{ label: "Maintenance & hosting", href: "#" },
		],
	},
	{
		title: "Studio",
		links: [
			{ label: "Work", href: "#work" },
			{ label: "Why us", href: "#why" },
			{ label: "Reviews", href: "#testimonials" },
		],
	},
	{
		title: "Talk",
		links: [
			{ label: "hello@cwsio.com", href: "mailto:hello@cwsio.com" },
			{ label: "Whatsapp Martin", href: "https://wa.me/", target: "_blank" },
			{ label: "Instagram", href: "https://instagram.com/", target: "_blank" },
			{ label: "LinkedIn", href: "https://linkedin.com/", target: "_blank" },
		],
	},
];
const year = new Date().getFullYear();
---

<footer class="foot">
	<!-- Mid: links + brand -->
	<div class="wrap foot-mid">
		<div class="foot-brand">
			<a href="/" class="foot-mark" aria-label="Creative Web Services — home">
				<img src="/cws-logo-real.svg" alt="Creative Web Services" />
			</a>
		</div>

		<nav class="foot-cols" aria-label="Footer">
			{
				cols.map((c) => (
					<div class="col">
						<h4 class="col-title">{c.title}</h4>
						<ul>
							{c.links.map((l) => (
								<li>
									<a href={l.href} target={l.target} rel={l.target ? "noopener" : undefined}>
										<span class="link-inner">
											<span>{l.label}</span>
											<span>{l.label}</span>
										</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</nav>
	</div>

	<!-- Edge-to-edge wordmark — infinite horizontal marquee -->
	<div class="foot-watermark" aria-hidden="true">
		<div class="wm-track">
			<span class="wm-text">creative web services</span>
			<span class="wm-dot">●</span>
			<span class="wm-text">creative web services</span>
			<span class="wm-dot">●</span>
			<span class="wm-text">creative web services</span>
			<span class="wm-dot">●</span>
			<span class="wm-text">creative web services</span>
			<span class="wm-dot">●</span>
		</div>
	</div>

	<!-- Bottom bar -->
	<div class="wrap foot-bottom">
		<span>© {year} Creative Web Services LLC.</span>
		<a href="#" class="back-top">
			Back to top
			<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
				<path d="M12 19V5M5 12l7-7 7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</a>
	</div>
</footer>

<style>
	.foot {
		position: relative;
		background: var(--paper);
		padding-top: clamp(60px, 8vw, 110px);
		overflow: hidden;
		isolation: isolate;
	}
	.foot::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 80% 10%, color-mix(in srgb, var(--gold) 12%, transparent) 0%, transparent 45%),
			radial-gradient(ellipse at 12% 90%, color-mix(in srgb, var(--teal) 10%, transparent) 0%, transparent 50%);
		pointer-events: none;
		z-index: -1;
	}

	.foot-top {
		display: flex;
		flex-direction: column;
		gap: 22px;
		padding-bottom: clamp(48px, 6vw, 80px);
	}

	.foot-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0;
		padding: 8px 16px 8px 14px;
		background: #fff;
		border: 1px solid var(--hairline);
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--teal-deep);
		align-self: flex-start;
	}
	.foot-eyebrow .dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #34a853;
		box-shadow: 0 0 0 3px rgba(52, 168, 83, 0.18);
		animation: foot-pulse 1.8s ease-in-out infinite;
	}
	@keyframes foot-pulse {
		0%, 100% { box-shadow: 0 0 0 3px rgba(52, 168, 83, 0.18); }
		50% { box-shadow: 0 0 0 6px rgba(52, 168, 83, 0.05); }
	}

	.foot-headline {
		font-size: clamp(56px, 9vw, 152px);
		margin: 0;
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.035em;
	}
	.foot-headline .line { display: block; }
	.foot-headline em {
		font-style: normal;
		color: var(--orange);
	}

	.big-mail {
		display: inline-flex;
		align-items: center;
		gap: 18px;
		margin-top: 12px;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: clamp(28px, 4vw, 56px);
		letter-spacing: -0.025em;
		color: var(--teal-deep);
		padding: 14px 0;
		border-top: 1px solid var(--hairline-strong);
		border-bottom: 1px solid var(--hairline-strong);
		position: relative;
		overflow: hidden;
		transition: color 0.4s ease, padding 0.4s ease;
		align-self: stretch;
		justify-content: space-between;
	}
	.big-mail::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--teal-ink);
		transform: translateY(101%);
		transition: transform 0.55s cubic-bezier(0.7, 0, 0.2, 1);
		z-index: -1;
	}
	.big-mail:hover {
		color: var(--paper);
		padding-left: 24px;
		padding-right: 24px;
	}
	.big-mail:hover::before { transform: translateY(0); }
	.mail-arrow {
		display: inline-flex;
		width: 56px;
		height: 56px;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--orange);
		color: #fff;
		transition: transform 0.4s cubic-bezier(0.34, 1.4, 0.64, 1);
	}
	.big-mail:hover .mail-arrow { transform: rotate(-45deg) scale(1.1); }

	.foot-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 8px;
	}
	.foot-pill {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 12px 20px;
		border-radius: 999px;
		background: var(--teal-ink);
		color: #fff;
		font-weight: 600;
		font-size: 0.92rem;
		transition: background 0.25s ease, gap 0.25s ease;
	}
	.foot-pill:hover { background: var(--orange); gap: 14px; }
	.foot-pill.ghost {
		background: transparent;
		color: var(--teal-deep);
		border: 1px solid var(--hairline-strong);
	}
	.foot-pill.ghost:hover {
		background: #fff;
		border-color: var(--teal);
	}

	/* Marquee */
	.foot-marquee {
		overflow: hidden;
		padding: 18px 0;
		border-top: 1px solid var(--hairline-strong);
		border-bottom: 1px solid var(--hairline-strong);
		background: var(--teal-wash);
	}
	.m-track {
		display: flex;
		gap: 36px;
		flex-shrink: 0;
		animation: m-scroll 28s linear infinite;
		white-space: nowrap;
	}
	.m-item {
		display: inline-flex;
		align-items: center;
		gap: 36px;
		font-family: var(--font-sans);
		font-weight: 800;
		font-size: clamp(22px, 2.4vw, 36px);
		letter-spacing: -0.02em;
		color: var(--teal-ink);
		text-transform: lowercase;
	}
	.m-dot {
		color: var(--orange);
		font-size: 0.7em;
	}
	@keyframes m-scroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* Mid */
	.foot-mid {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.6fr);
		gap: clamp(32px, 5vw, 80px);
		padding: clamp(28px, 3vw, 48px) var(--gutter) clamp(20px, 2vw, 32px);
	}

	@media (max-width: 760px) {
		.foot-mid { grid-template-columns: 1fr; }
	}

	.foot-mark img {
		height: 140px;
		width: auto;
		display: block;
	}
	@media (max-width: 760px) {
		.foot-mark img { height: 96px; }
	}
	.foot-tag {
		margin: 22px 0 0;
		max-width: 320px;
		color: var(--ink-mute);
		font-size: 0.96rem;
		line-height: 1.55;
	}

	.foot-cols {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	@media (max-width: 600px) {
		.foot-cols { grid-template-columns: repeat(2, 1fr); gap: 28px; }
	}

	.col-title {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 0.76rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--orange);
		margin: 0 0 16px;
	}
	.col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.col a {
		display: inline-block;
		font-size: 1rem;
		font-weight: 500;
		color: var(--teal-ink);
		position: relative;
		overflow: hidden;
		line-height: 1.4;
		height: 1.4em;
	}
	.link-inner {
		display: flex;
		flex-direction: column;
		transition: transform 0.45s cubic-bezier(0.7, 0, 0.2, 1);
	}
	.link-inner > span {
		display: block;
		line-height: 1.4;
		height: 1.4em;
	}
	.link-inner > span:nth-child(2) {
		color: var(--orange);
	}
	.col a:hover .link-inner {
		transform: translateY(-100%);
	}

	/* Watermark — edge to edge, infinite marquee */
	.foot-watermark {
		position: relative;
		width: 100%;
		overflow: hidden;
		line-height: 0;
	}
	.wm-track {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		white-space: nowrap;
		animation: wm-scroll 28s linear infinite;
		will-change: transform;
	}
	.wm-text {
		font-family: var(--font-sans);
		font-weight: 900;
		color: var(--teal-deep);
		font-size: 13vw;
		letter-spacing: -0.05em;
		line-height: 0.92;
	}
	.wm-dot {
		color: var(--orange);
		font-size: 6vw;
		line-height: 0.92;
		display: inline-block;
		transform: translateY(-0.15em);
	}
	@keyframes wm-scroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}
	.foot-watermark:hover .wm-track {
		animation-play-state: paused;
	}
	@media (prefers-reduced-motion: reduce) {
		.wm-track { animation: none; }
	}

	/* Bottom */
	.foot-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 22px var(--gutter) 24px;
		border-top: 1px solid var(--hairline);
		font-size: 0.84rem;
		color: var(--ink-mute);
		font-weight: 500;
	}
	.back-top {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--teal-deep);
		font-weight: 600;
		transition: color 0.2s ease, gap 0.2s ease;
	}
	.back-top:hover { color: var(--orange); gap: 12px; }

	@media (max-width: 600px) {
		.foot-bottom { flex-direction: column; gap: 8px; align-items: flex-start; }
	}
</style>

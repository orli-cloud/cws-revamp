---
const pillars = [
	{
		title: "You'll love it",
		copy: "We don't call it done until you're proud to put your name on it.",
		quote:
			"The dedication of Martin and his team to go above and beyond is why our new site is something we take pride in every day.",
		who: "Elie Burg",
	},
	{
		title: "It will be easy",
		copy:
			"Whatever you need, we're on it and you can always reach the person making it happen.",
		quote:
			"Communication was seamless, deadlines were met, and the entire process felt smooth and professional.",
		who: "Mimi Friedman",
	},
	{
		title: "It's made for you",
		copy:
			"Whether you know what you want or not, we'll figure out what's best for your needs and execute it to perfection.",
		quote:
			"They really listened to my ideas and understood my goals. They were always willing to make adjustments and bring my vision to life.",
		who: "Isaac Cizment",
	},
	{
		title: "The best you can get",
		copy:
			"Every detail of your project is held to the highest standard, backed by strategy and skill.",
		quote:
			"Hands down one of the best decisions I made for my business. The quality of work is top-tier. Very professional.",
		who: "Mordechai Babad",
	},
];
---

<section id="why" class="why" data-flip-zone>
	<div class="wrap">
		<header class="why-head reveal">
			<h2 class="display why-title">
				Why 400+ companies<br />
				<span class="ital">choose CWS.</span>
			</h2>
			<p class="why-sub">
				Your project is our project. And that project is in good hands.
			</p>
		</header>

		<ul class="cards">
			{
				pillars.map((p, i) => (
					<li class="card-wrap reveal" style={`transition-delay: ${i * 80}ms`}>
						<article class="reveal-card">
							<div class="face front">
								<header class="f-top">
									<span class="f-mark" aria-hidden="true">
										<svg viewBox="0 0 32 32" width="22" height="22">
											<path
												d="M6 16l6 6L26 8"
												fill="none"
												stroke="currentColor"
												stroke-width="2.6"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
									</span>
								</header>
								<h3 class="f-title">{p.title}</h3>
								<p class="f-copy">{p.copy}</p>
							</div>

							<div class="face back">
								<svg
									class="back-quote"
									viewBox="0 0 48 36"
									aria-hidden="true"
								>
									<path
										d="M0 36V18c0-9.9 7.2-18 18-18v6c-6.6 0-12 5.4-12 12h6v18H0Zm24 0V18c0-9.9 7.2-18 18-18v6c-6.6 0-12 5.4-12 12h6v18H24Z"
										fill="currentColor"
									/>
								</svg>
								<blockquote class="back-quote-text">{p.quote}</blockquote>
								<footer class="back-foot">
									<span class="back-line" aria-hidden="true" />
									<span class="back-name">{p.who}</span>
								</footer>
							</div>
						</article>
					</li>
				))
			}
		</ul>
	</div>

	<div class="why-cursor" data-flip-cursor aria-hidden="true">
		<svg class="why-arrow" viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
			<path
				d="M3 2 L 3 18 L 8 14 L 11 21 L 14 19.5 L 11 13 L 17 13 Z"
				fill="var(--teal-ink)"
				stroke="#fff"
				stroke-width="1.5"
				stroke-linejoin="round"
			/>
		</svg>
		<span class="why-pill">See the proof</span>
	</div>
</section>

<style>
	.why {
		padding: clamp(36px, 5vw, 72px) 0 clamp(60px, 8vw, 120px);
		background: var(--paper);
		position: relative;
	}
	.why::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image: radial-gradient(
			circle at 1px 1px,
			var(--hairline) 1px,
			transparent 0
		);
		background-size: 36px 36px;
		opacity: 0.65;
		pointer-events: none;
		mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 80%, transparent 100%);
		-webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 80%, transparent 100%);
	}

	.why-head {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
		gap: clamp(20px, 4vw, 64px);
		align-items: end;
		margin-bottom: clamp(40px, 5vw, 64px);
		position: relative;
	}
	.why-title {
		font-size: clamp(40px, 5.6vw, 84px);
		margin: 0;
		grid-column: 1;
	}
	.why-title .ital {
		font-style: normal;
		font-weight: 300;
		color: var(--teal);
	}
	.why-sub {
		grid-column: 2;
		align-self: end;
		font-size: clamp(15px, 1.1vw, 18px);
		color: var(--ink-mute);
		max-width: 380px;
		margin: 0;
		padding-bottom: 8px;
	}

	@media (max-width: 760px) {
		.why-head { grid-template-columns: 1fr; align-items: start; }
		.why-title, .why-sub { grid-column: 1; }
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 18px;
		list-style: none;
		padding: 0;
		margin: 0;
		position: relative;
		z-index: 1;
	}
	@media (max-width: 980px) {
		.cards { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 540px) {
		.cards { grid-template-columns: 1fr; }
	}

	.card-wrap {
		perspective: 1400px;
		min-height: 360px;
	}

	.reveal-card {
		position: relative;
		width: 100%;
		height: 100%;
		min-height: 360px;
		border-radius: 22px;
		overflow: hidden;
		cursor: none;
		isolation: isolate;
	}

	.face {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		gap: 14px;
		padding: 26px 24px 24px;
		border-radius: 22px;
		border: 1px solid var(--hairline);
		transition: transform 0.65s cubic-bezier(0.7, 0, 0.2, 1), opacity 0.4s ease;
		will-change: transform;
	}

	/* Slide-up reveal: front slides up & out, back slides up from below */
	.front { transform: translateY(0); }
	.back { transform: translateY(101%); border-color: transparent; }

	.card-wrap:hover .front { transform: translateY(-101%); }
	.card-wrap:hover .back { transform: translateY(0); }

	.front {
		background: #fff;
		color: var(--teal-ink);
	}
	.front .f-top {
		display: flex;
		justify-content: flex-end;
	}
	.f-mark {
		display: inline-flex;
		width: 40px;
		height: 40px;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--teal-soft);
		color: var(--teal);
	}
	.f-title {
		font-family: var(--font-sans);
		font-weight: 700;
		letter-spacing: -0.025em;
		font-size: clamp(22px, 2vw, 30px);
		margin: 0;
		color: var(--teal-ink);
		line-height: 1.05;
	}
	.f-copy {
		margin: 0;
		font-size: 0.96rem;
		line-height: 1.55;
		color: var(--ink-mute);
	}
	.back {
		background: var(--teal-ink);
		color: var(--paper);
		justify-content: space-between;
		overflow: hidden;
	}
	.back::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse at 80% 10%,
			rgba(252, 182, 38, 0.22) 0%,
			transparent 55%
		), radial-gradient(
			ellipse at 10% 90%,
			rgba(247, 128, 64, 0.2) 0%,
			transparent 55%
		);
		pointer-events: none;
	}
	.back-quote {
		width: 30px;
		height: auto;
		color: var(--orange);
		opacity: 0.95;
		position: relative;
	}
	.back-quote-text {
		margin: 8px 0 0;
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: clamp(15px, 1.2vw, 18px);
		line-height: 1.4;
		color: var(--paper);
		position: relative;
	}
	.back-foot {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin-top: auto;
		padding-top: 16px;
		position: relative;
	}
	.back-line {
		width: 32px;
		height: 1px;
		background: var(--gold);
	}
	.back-name {
		font-weight: 700;
		font-size: 0.92rem;
		letter-spacing: -0.005em;
		color: var(--gold);
	}

	/* Custom cursor — pointer + pill (matches Services style) */
	.why-cursor {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		opacity: 0;
		z-index: 200;
		transform: translate3d(-200px, -200px, 0);
		transition: opacity 0.2s ease;
	}
	.why-cursor.is-on { opacity: 1; }

	.why-arrow {
		position: absolute;
		top: 0;
		left: 0;
		filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.35));
	}
	.why-pill {
		position: absolute;
		top: 12px;
		left: 38px;
		display: inline-flex;
		align-items: center;
		padding: 10px 18px;
		background: var(--orange);
		color: #fff;
		border-radius: 999px;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 0.86rem;
		white-space: nowrap;
		box-shadow: 0 14px 30px -10px rgba(247, 128, 64, 0.55);
		animation: why-pill-bob 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}
	@keyframes why-pill-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-3px); }
	}
</style>

<script>
	const zone = document.querySelector<HTMLElement>("[data-flip-zone]");
	const cursor = document.querySelector<HTMLElement>("[data-flip-cursor]");
	const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const isTouch = window.matchMedia("(hover: none)").matches;

	if (zone && cursor && !reduce && !isTouch) {
		// Cursor only shows when hovering over the actual cards, not the section background
		let raf = 0;
		let tx = -200, ty = -200, mx = -200, my = -200;
		const tick = () => {
			tx += (mx - tx) * 0.28;
			ty += (my - ty) * 0.28;
			cursor.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
			if (Math.abs(mx - tx) > 0.3 || Math.abs(my - ty) > 0.3) {
				raf = requestAnimationFrame(tick);
			} else {
				raf = 0;
			}
		};
		const onMove = (e: MouseEvent) => {
			mx = e.clientX;
			my = e.clientY;
			if (!raf) raf = requestAnimationFrame(tick);
		};
		document.querySelectorAll<HTMLElement>(".card-wrap").forEach((card) => {
			card.addEventListener("mouseenter", (e) => {
				const ev = e as MouseEvent;
				mx = ev.clientX; my = ev.clientY;
				tx = mx; ty = my;
				cursor.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
				cursor.classList.add("is-on");
			});
			card.addEventListener("mouseleave", () => {
				cursor.classList.remove("is-on");
			});
			card.addEventListener("mousemove", onMove);
		});
	}
</script>

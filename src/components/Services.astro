		bg: "https://cms-cdn.cwsio.com/wp-content/uploads/2025/04/Sunray-ABA-1-Thumbnail.jpg",
		accent: "var(--teal)",
		samples: [
			{ name: "Sunray ABA", img: "https://cms-cdn.cwsio.com/wp-content/uploads/2025/04/Sunray-ABA-1-Thumbnail.jpg" },

services.push(
	{
		key: "marketing",
		title: "Marketing + Printing",
		blurb: "Print, decks, social — cohesive across every touchpoint.",
		cta: "See the work",
		bg: "https://cms-cdn.cwsio.com/wp-content/uploads/2025/08/New-Styles-Sign-1-Thumbnail.jpg",
		accent: "var(--orange)",
		samples: [
			{ name: "New Styles Sign", img: "https://cms-cdn.cwsio.com/wp-content/uploads/2025/08/New-Styles-Sign-1-Thumbnail.jpg" },
			{ name: "Mindy Blumenfeld", img: "https://cms-cdn.cwsio.com/wp-content/uploads/2024/01/Mindy-Blumenfeld-LCSW-1-Thumbnail.jpg" },
		],
	},
	{
		key: "care",
		title: "Maintenance & hosting",
		blurb: "Always-on care so your site keeps quietly working.",
		cta: "See the work",
		bg: "https://cms-cdn.cwsio.com/wp-content/uploads/2024/01/Heisinger-Bluffs-1-Thumbnail.jpg",
		accent: "var(--gold)",
		samples: [
			{ name: "Heisinger Bluffs", img: "https://cms-cdn.cwsio.com/wp-content/uploads/2024/01/Heisinger-Bluffs-1-Thumbnail.jpg" },
			{ name: "Maple Leaf Healthcare", img: "https://cms-cdn.cwsio.com/wp-content/uploads/2024/01/Maple-Leaf-Healthcare-1-Thumbnail.jpg" },
		],
	}
